# Disable Apache output compression for the Passenger app.
# Apache's mod_deflate was corrupting the gzipped response (full page
# compressed to a broken 23-byte blob -> blank screen).
SetEnv no-gzip 1
SetEnv dont-vary 1

<IfModule mod_deflate.c>
  SetEnvIfNoCase Request_URI .* no-gzip dont-vary
</IfModule>

<IfModule mod_headers.c>
  # Ensure no stale content-encoding is advertised
  Header unset Content-Encoding
</IfModule>

<IfModule mod_deflate.c>
  SetEnvIfNoCase Request_URI .* no-gzip dont-vary
</IfModule>

