# ── Database ────────────────────────────────────────────────────────────────────
# PlanetScale / Aiven / Railway / Bluehost MySQL
DB_HOST=your-mysql-host.example.com
DB_PORT=3306
DB_NAME=enternstech
DB_USER=enternstech_user
DB_PASS=your_secure_password

# ── Security ─────────────────────────────────────────────────────────────────────
SECRET_KEY=generate-with--python-secrets-token-hex-32
ADMIN_PASSWORD=your_admin_password

# ── Razorpay ────────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX

# ── Email (SMTP) ─────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM_NAME=Enterns Tech
SMTP_FROM_EMAIL=noreply@enternstech.com
ADMIN_EMAIL=admin@enternstech.com
MENTOR_EMAIL=mentor@enternstech.com

# ── App ───────────────────────────────────────────────────────────────────────────
APP_BASE_URL=https://your-domain.com
APP_ENV=production
